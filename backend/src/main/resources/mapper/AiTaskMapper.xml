<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lanyan.aidrama.mapper.AiTaskMapper">

    <!-- 查询到期需要轮询的 AI 任务 -->
    <select id="selectPollableTasks" resultType="com.lanyan.aidrama.entity.AiTask">
        SELECT *
        FROM ai_task
        WHERE status = 1
          AND next_poll_time &lt;= NOW()
        ORDER BY next_poll_time
        LIMIT 50
    </select>

</mapper>
